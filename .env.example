# OpenKiln environment variables
# Copy relevant variables to your shell profile or .env file.
# Environment variables take precedence over ~/.openkiln/config.toml.

# ── Database ──────────────────────────────────────────────────

# Override the default core database path
# Default: ~/.openkiln/core.db
# OPENKILN_CORE_DB=~/.openkiln/core.db

# Override the default skills directory
# Default: ~/.openkiln/skills
# OPENKILN_SKILLS_DIR=~/.openkiln/skills

# ── Skills ────────────────────────────────────────────────────

# OrbiSearch — email verification
# Get a free key at: https://orbisearch.com/dashboard/api-keys
# ORBISEARCH_API_KEY=

# Smartlead — outreach sequences
# SMARTLEAD_API_KEY=
